<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SysPulse — {{ report.system.hostname }}</title>
<style>
/* ── Base ──────────────────────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#0f0f0f;color:#e0e0e0;font-size:14px;line-height:1.6}
a{color:#60a5fa;text-decoration:none}
/* ── Header ────────────────────────────────────────────────────────────── */
header{background:#111827;border-bottom:1px solid #1f2937;padding:1rem 2rem;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap}
.logo{font-weight:800;font-size:1.1rem;color:#fff;letter-spacing:.5px}
.logo span{color:#60a5fa}
.host-info{flex:1;min-width:200px}
.host-info .hostname{font-size:1.1rem;font-weight:700;color:#fff}
.host-info .meta{color:#6b7280;font-size:0.8rem;margin-top:.2rem}
.score-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.5rem 1.2rem;border-radius:6px;font-weight:800;font-size:1.3rem;white-space:nowrap}
.CRITICAL,.score-CRITICAL{background:#450a0a;color:#f87171;border:1px solid #991b1b}
.HIGH,.score-HIGH{background:#431407;color:#fb923c;border:1px solid #9a3412}
.MEDIUM,.score-MEDIUM{background:#422006;color:#facc15;border:1px solid #92400e}
.LOW,.score-LOW{background:#052e16;color:#4ade80;border:1px solid #166534}
/* ── Tabs ───────────────────────────────────────────────────────────────── */
.tab-bar{background:#111827;border-bottom:1px solid #1f2937;display:flex;padding:0 2rem}
.tab-btn{padding:.75rem 1.5rem;cursor:pointer;border:none;background:transparent;color:#6b7280;font-size:.9rem;font-weight:600;border-bottom:3px solid transparent;transition:color .15s,border-color .15s}
.tab-btn:hover{color:#e0e0e0}
.tab-btn.active{color:#60a5fa;border-bottom-color:#60a5fa}
.tab-pane{display:none}
.tab-pane.active{display:block}
/* ── Container ──────────────────────────────────────────────────────────── */
.container{max-width:1200px;margin:0 auto;padding:2rem}
/* ── Summary grid ───────────────────────────────────────────────────────── */
.summary-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:.8rem;margin:1.5rem 0}
.summary-card{background:#1f2937;border:1px solid #374151;border-radius:8px;padding:.9rem;text-align:center}
.summary-card .count{font-size:1.8rem;font-weight:800;line-height:1}
.summary-card .label{font-size:.7rem;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-top:.3rem}
.c-critical{color:#f87171}.c-high{color:#fb923c}.c-medium{color:#facc15}
.c-low{color:#4ade80}.c-info{color:#94a3b8}.c-pass{color:#34d399}
/* ── Tables ─────────────────────────────────────────────────────────────── */
table{width:100%;border-collapse:collapse;margin:1rem 0;font-size:.85rem}
th{text-align:left;padding:.55rem 1rem;background:#1f2937;color:#9ca3af;font-weight:600;border-bottom:1px solid #374151;font-size:.75rem;text-transform:uppercase;letter-spacing:.4px}
td{padding:.6rem 1rem;border-bottom:1px solid #1f2937;vertical-align:top}
tr:last-child td{border-bottom:none}
tr:hover td{background:#1a2234}
/* ── Severity badges ────────────────────────────────────────────────────── */
.sev{font-weight:700;font-size:.72rem;padding:.2rem .55rem;border-radius:3px;white-space:nowrap}
.sev-critical{background:#450a0a;color:#f87171}.sev-high{background:#431407;color:#fb923c}
.sev-medium{background:#422006;color:#facc15}.sev-low{background:#052e16;color:#4ade80}
.sev-info{background:#1e293b;color:#94a3b8}
/* ── Remediation ────────────────────────────────────────────────────────── */
.remediation{background:#1f2937;border-left:3px solid #facc15;padding:1rem 1.2rem;border-radius:0 6px 6px 0;margin:1rem 0}
.remediation ol{margin:0;padding-left:1.5rem}
.remediation li{margin:.4rem 0;color:#d1d5db}
/* ── Section headings ───────────────────────────────────────────────────── */
h2{color:#e5e7eb;font-size:1rem;font-weight:700;margin:2rem 0 .6rem;border-bottom:1px solid #1f2937;padding-bottom:.4rem;text-transform:uppercase;letter-spacing:.5px}
h3{color:#9ca3af;font-size:.8rem;font-weight:600;margin:1.4rem 0 .4rem;text-transform:uppercase;letter-spacing:.5px}
/* ── Profile cards ──────────────────────────────────────────────────────── */
.profile-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;margin:1rem 0}
.profile-card{background:#1f2937;border:1px solid #374151;border-radius:8px;overflow:hidden}
.profile-card .card-title{background:#111827;padding:.6rem 1rem;font-size:.75rem;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px}
.profile-card table{margin:0}
.profile-card td{padding:.45rem 1rem;border-bottom:1px solid #111827;font-size:.82rem}
.profile-card td:first-child{color:#6b7280;width:45%;white-space:nowrap}
.profile-card tr:last-child td{border-bottom:none}
/* ── SW filter ──────────────────────────────────────────────────────────── */
.filter-input{width:100%;padding:.5rem .8rem;background:#1f2937;border:1px solid #374151;color:#e0e0e0;border-radius:6px;margin-bottom:.5rem;font-size:.85rem}
.filter-input:focus{outline:none;border-color:#60a5fa}
/* ── Details/summary ────────────────────────────────────────────────────── */
details{margin-bottom:.5rem;border:1px solid #1f2937;border-radius:6px;overflow:hidden}
summary{cursor:pointer;padding:.65rem 1rem;background:#1f2937;color:#e5e7eb;font-size:.85rem;font-weight:600;list-style:none;display:flex;align-items:center;gap:.5rem}
summary::before{content:'▶';font-size:.6rem;color:#6b7280;transition:transform .2s}
details[open] summary::before{transform:rotate(90deg)}
summary:hover{background:#1a2234}
/* ── Footer ─────────────────────────────────────────────────────────────── */
.footer{color:#374151;font-size:.75rem;margin-top:3rem;border-top:1px solid #1f2937;padding-top:1rem}
/* ── Security agent badges ──────────────────────────────────────────────── */
.agent-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:.6rem;margin:1rem 0}
.agent-cat{background:#111827;border:1px solid #1f2937;border-radius:8px;padding:.7rem 1rem}
.agent-cat .cat-name{font-size:.7rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-bottom:.4rem}
.agent-cat .agent-item{font-size:.8rem;padding:.2rem 0;display:flex;align-items:center;gap:.4rem}
.dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.dot-running{background:#4ade80}.dot-stopped{background:#fb923c}.dot-installed{background:#60a5fa}.dot-detected{background:#a78bfa}
.coverage-bar{display:flex;gap:.4rem;flex-wrap:wrap;margin:.6rem 0}
.cov-badge{padding:.25rem .7rem;border-radius:4px;font-size:.75rem;font-weight:700;border:1px solid}
.cov-yes{background:#052e16;color:#4ade80;border-color:#166534}
.cov-no{background:#1f2937;color:#4b5563;border-color:#374151}
</style>
</head>
<body>

<!-- ── Header ─────────────────────────────────────────────────────────── -->
<header>
  <div class="logo">e<span>CISO</span> SysPulse</div>
  <div class="host-info">
    <div class="hostname">{{ report.system.hostname }}</div>
    <div class="meta">
      {{ report.system.os_name }} {{ report.system.os_version }} (Build {{ report.system.os_build }}) &nbsp;·&nbsp;
      {{ report.system.architecture }} &nbsp;·&nbsp;
      User: {{ report.system.current_user }}{% if report.system.is_admin %} (Admin){% endif %} &nbsp;·&nbsp;
      {{ report.generated_at.strftime('%Y-%m-%d %H:%M UTC') }}
    </div>
  </div>
  <span class="score-badge score-{{ report.score.tier }}">
    {{ report.score.overall }}/10 &nbsp; {{ report.score.tier }}
  </span>
</header>

<!-- ── Tab bar ────────────────────────────────────────────────────────── -->
<div class="tab-bar">
  <button class="tab-btn active" onclick="switchTab('security',this)">Security Report</button>
  <button class="tab-btn" onclick="switchTab('inventory',this)">System Inventory</button>
  <button class="tab-btn" onclick="switchTab('network',this)">Network Discovery</button>
</div>

<!-- ════════════════════════════════════════════════════════════════════ -->
<!-- TAB 1 — SECURITY REPORT                                            -->
<!-- ════════════════════════════════════════════════════════════════════ -->
<div id="tab-security" class="tab-pane active">
<div class="container">

  <h2>Summary</h2>
  <div class="summary-grid">
    <div class="summary-card"><div class="count c-critical">{{ report.score.counts.get('critical',0) }}</div><div class="label">Critical</div></div>
    <div class="summary-card"><div class="count c-high">{{ report.score.counts.get('high',0) }}</div><div class="label">High</div></div>
    <div class="summary-card"><div class="count c-medium">{{ report.score.counts.get('medium',0) }}</div><div class="label">Medium</div></div>
    <div class="summary-card"><div class="count c-low">{{ report.score.counts.get('low',0) }}</div><div class="label">Low</div></div>
    <div class="summary-card"><div class="count c-pass">{{ report.score.counts.get('pass',0) }}</div><div class="label">Passed</div></div>
  </div>

  {% if report.inventory and report.inventory.security_agents %}
  {% set agents = report.inventory.security_agents %}
  {% set all_cats = ['EDR','AV','Proxy','VPN','MDM','PAM','SIEM','DLP','Identity'] %}
  {% set detected_cats = agents | map(attribute='category') | list %}
  <h2>Security Coverage</h2>
  <div class="coverage-bar">
    {% for cat in all_cats %}
      {% if cat in detected_cats %}
        <span class="cov-badge cov-yes">✓ {{ cat }}</span>
      {% else %}
        <span class="cov-badge cov-no">✗ {{ cat }}</span>
      {% endif %}
    {% endfor %}
  </div>
  <div class="agent-grid">
    {% for cat in all_cats %}
    {% set cat_agents = agents | selectattr('category','equalto',cat) | list %}
    {% if cat_agents %}
    <div class="agent-cat">
      <div class="cat-name">{{ cat }}</div>
      {% for a in cat_agents %}
      {% set dot_cls = 'dot-running' if a.status == 'running' else 'dot-stopped' if a.status == 'stopped' else 'dot-installed' if a.status == 'installed' else 'dot-detected' %}
      <div class="agent-item">
        <span class="dot {{ dot_cls }}" title="{{ a.status }}"></span>
        <span title="{{ a.detected_by }}: {{ a.indicator }}">{{ a.name }}</span>
        {% if a.version %}<span style="color:#4b5563;font-size:.7rem">{{ a.version[:12] }}</span>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}
    {% endfor %}
  </div>
  <p style="font-size:.73rem;color:#4b5563;margin-bottom:1rem">
    <span style="color:#4ade80">●</span> running &nbsp;
    <span style="color:#fb923c">●</span> stopped &nbsp;
    <span style="color:#60a5fa">●</span> installed &nbsp;
    <span style="color:#a78bfa">●</span> detected
  </p>
  {% endif %}

  <h2>Findings</h2>
  <table>
    <thead><tr><th>ID</th><th>Title</th><th>Severity</th><th>Score</th><th>CVSS Vector</th><th>Affected</th></tr></thead>
    <tbody>
    {% for m in report.score.ranked_matches %}
    <tr>
      <td style="font-family:monospace;font-size:.78rem;white-space:nowrap">{{ m.finding.id }}</td>
      <td>{{ m.finding.title }}<br><small style="color:#6b7280">{{ m.finding.description }}</small></td>
      <td><span class="sev sev-{{ m.severity.value }}">{{ m.severity.value.upper() }}</span></td>
      <td style="font-weight:700">{{ "%.1f"|format(m.final_score) }}</td>
      <td style="font-size:.75rem;font-family:monospace;color:#6b7280">{{ m.cvss_vector or '—' }}</td>
      <td style="font-size:.8rem">{{ m.finding.affected_resources|join(', ') or '—' }}</td>
    </tr>
    {% else %}
    <tr><td colspan="6" style="text-align:center;color:#6b7280;padding:2rem">No findings.</td></tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Remediation Steps</h2>
  <div class="remediation">
    <ol>
    {% set seen = namespace(steps=[]) %}
    {% for m in report.score.ranked_matches %}
      {% for step in m.remediation_steps %}
        {% if step not in seen.steps %}
          {% set _ = seen.steps.append(step) %}
          <li>{{ step }}</li>
        {% endif %}
      {% endfor %}
    {% endfor %}
    {% if not seen.steps %}<li style="color:#6b7280">No remediation steps available.</li>{% endif %}
    </ol>
  </div>

  {% if report.compliance_results %}
  <h2>Compliance Coverage</h2>
  <table>
    <thead><tr><th>Framework</th><th>Version</th><th>Controls</th><th>Passing</th><th>Failing</th><th>Not Covered</th><th>Pass Rate</th></tr></thead>
    <tbody>
    {% for r in report.compliance_results %}
    {% set rate_color = "#4ade80" if r.pass_rate >= 80 else "#facc15" if r.pass_rate >= 50 else "#f87171" %}
    <tr>
      <td>{{ r.framework }}</td>
      <td style="color:#6b7280">{{ r.version }}</td>
      <td style="text-align:right">{{ r.total_controls }}</td>
      <td style="text-align:right;color:#4ade80">{{ r.passing }}</td>
      <td style="text-align:right;color:{% if r.failing %}#f87171{% else %}#6b7280{% endif %}">{{ r.failing }}</td>
      <td style="text-align:right;color:#6b7280">{{ r.not_covered }}</td>
      <td style="text-align:right;font-weight:700;color:{{ rate_color }}">{{ r.pass_rate }}%</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Compliance Details</h2>
  {% for r in report.compliance_results %}
  <details>
    <summary>{{ r.framework }} — {{ r.passing }}/{{ r.total_controls }} controls passing ({{ r.pass_rate }}%)</summary>
    <table>
      <thead><tr><th>Control ID</th><th>Title</th><th>Category</th><th>Status</th></tr></thead>
      <tbody>
      {% for d in r.details %}
      {% set st_color = "#4ade80" if d.status == "pass" else "#f87171" if d.status == "fail" else "#4b5563" %}
      <tr>
        <td style="font-family:monospace;font-size:.8rem;white-space:nowrap">{{ d.control.id }}</td>
        <td>{{ d.control.title }}</td>
        <td style="color:#6b7280;font-size:.8rem">{{ d.control.category }}</td>
        <td style="font-weight:700;color:{{ st_color }}">{{ d.status.upper().replace("_"," ") }}</td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
  </details>
  {% endfor %}
  {% endif %}

  <p class="footer">Generated by SysPulse v{{ report.tool_version }}</p>
</div>
</div><!-- /tab-security -->

<!-- ════════════════════════════════════════════════════════════════════ -->
<!-- TAB 2 — SYSTEM INVENTORY                                           -->
<!-- ════════════════════════════════════════════════════════════════════ -->
<div id="tab-inventory" class="tab-pane">
<div class="container">

{% set inv = report.inventory %}
{% set sys = report.system %}

  <!-- ── Computer Profile Summary ─────────────────────────────────────── -->
  <h2>Computer Profile Summary</h2>
  <div class="profile-grid">

    <!-- OS / Machine -->
    <div class="profile-card">
      <div class="card-title">Operating System &amp; Machine</div>
      <table>
        <tr><td>Hostname</td><td><strong>{{ sys.hostname }}</strong></td></tr>
        <tr><td>OS Name</td><td>{{ sys.os_name }}</td></tr>
        <tr><td>OS Version</td><td>{{ sys.os_version }}</td></tr>
        <tr><td>OS Build</td><td>{{ sys.os_build }}</td></tr>
        <tr><td>Architecture</td><td>{{ sys.architecture }}</td></tr>
        <tr><td>Domain Joined</td><td>{{ 'Yes' if sys.domain_joined else 'No' }}</td></tr>
        <tr><td>Azure AD Joined</td><td>{{ 'Yes' if sys.azure_ad_joined else 'No' }}</td></tr>
        <tr><td>Current User</td><td>{{ sys.current_user }}</td></tr>
        <tr><td>Admin Privileges</td><td style="color:{% if sys.is_admin %}#fb923c{% else %}#4ade80{% endif %}">{{ 'Yes' if sys.is_admin else 'No' }}</td></tr>
        <tr><td>Assessed At</td><td style="color:#6b7280;font-size:.8rem">{{ sys.assessed_at.strftime('%Y-%m-%d %H:%M UTC') }}</td></tr>
        {% if inv and inv.windows_product_id %}
        <tr><td>Windows Product ID</td><td style="font-family:monospace;font-size:.78rem">{{ inv.windows_product_id }}</td></tr>
        {% endif %}
      </table>
    </div>

    {% if inv %}

    <!-- Processor -->
    {% if inv.cpu %}
    <div class="profile-card">
      <div class="card-title">Processor</div>
      <table>
      {% for cpu in inv.cpu %}
        <tr><td>Name</td><td>{{ cpu.name }}</td></tr>
        <tr><td>Speed</td><td>{{ "%.2f"|format(cpu.max_clock_speed_mhz/1000) }} GHz</td></tr>
        <tr><td>Cores / Threads</td><td>{{ cpu.cores }} / {{ cpu.logical_processors }}</td></tr>
        {% if cpu.l2_cache_kb %}<tr><td>L2 Cache</td><td>{{ cpu.l2_cache_kb }} KB</td></tr>{% endif %}
        {% if cpu.l3_cache_kb %}<tr><td>L3 Cache</td><td>{{ cpu.l3_cache_kb }} KB</td></tr>{% endif %}
        <tr><td>Architecture</td><td>{{ cpu.architecture or sys.architecture }}</td></tr>
      {% endfor %}
      </table>
    </div>
    {% endif %}

    <!-- Motherboard / BIOS -->
    {% if inv.motherboard %}
    <div class="profile-card">
      <div class="card-title">Main Circuit Board &amp; BIOS</div>
      <table>
        <tr><td>Manufacturer</td><td>{{ inv.motherboard.manufacturer }}</td></tr>
        <tr><td>Product</td><td>{{ inv.motherboard.product }}</td></tr>
        {% if inv.motherboard.serial_number %}
        <tr><td>Serial Number</td><td style="font-family:monospace;font-size:.78rem">{{ inv.motherboard.serial_number }}</td></tr>
        {% endif %}
        {% if inv.motherboard.bios_version %}
        <tr><td>BIOS Version</td><td>{{ inv.motherboard.bios_version }}</td></tr>
        {% endif %}
        {% if inv.motherboard.bios_date %}
        <tr><td>BIOS Date</td><td>{{ inv.motherboard.bios_date }}</td></tr>
        {% endif %}
      </table>
    </div>
    {% endif %}

    <!-- Memory -->
    {% if inv.memory_modules %}
    <div class="profile-card">
      <div class="card-title">Memory — {{ inv.total_ram_gb }} GB Total</div>
      <table>
      {% for m in inv.memory_modules %}
        <tr><td>Module {{ loop.index }}</td><td>{{ m.capacity_gb }} GB{% if m.speed_mhz %} @ {{ m.speed_mhz }} MHz{% endif %}{% if m.form_factor %} ({{ m.form_factor }}){% endif %}</td></tr>
        {% if m.manufacturer %}<tr><td>&nbsp;&nbsp;Manufacturer</td><td style="color:#6b7280">{{ m.manufacturer }}</td></tr>{% endif %}
        {% if m.part_number %}<tr><td>&nbsp;&nbsp;Part Number</td><td style="font-family:monospace;font-size:.75rem;color:#6b7280">{{ m.part_number }}</td></tr>{% endif %}
      {% endfor %}
      </table>
    </div>
    {% endif %}

    {% endif %}{# inv #}
  </div>

  {% if inv %}

  <!-- ── Security Agents ─────────────────────────────────────────────── -->
  {% if inv.security_agents %}
  <h2>Security Agents ({{ inv.security_agents|length }} detected)</h2>
  <table>
    <thead><tr><th>Tool</th><th>Category</th><th>Status</th><th>Version</th><th>Detected By</th><th>Indicator</th></tr></thead>
    <tbody>
    {% for a in inv.security_agents %}
    {% set st_color = '#4ade80' if a.status == 'running' else '#fb923c' if a.status == 'stopped' else '#60a5fa' %}
    <tr>
      <td style="font-weight:600">{{ a.name }}</td>
      <td><span style="font-size:.75rem;padding:.15rem .5rem;background:#1e293b;border-radius:3px;color:#94a3b8">{{ a.category }}</span></td>
      <td style="font-weight:700;color:{{ st_color }}">{{ a.status }}</td>
      <td style="font-family:monospace;font-size:.78rem;color:#6b7280">{{ a.version or '—' }}</td>
      <td style="color:#6b7280;font-size:.78rem">{{ a.detected_by }}</td>
      <td style="font-family:monospace;font-size:.72rem;color:#4b5563;word-break:break-all">{{ a.indicator }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <!-- ── Storage ──────────────────────────────────────────────────────── -->
  {% if inv.disks %}
  <h2>Storage Drives</h2>
  <table>
    <thead><tr><th>Model</th><th>Size</th><th>Type</th><th>Interface</th><th>Partitions</th><th>Serial Number</th></tr></thead>
    <tbody>
    {% for d in inv.disks %}
    <tr>
      <td>{{ d.model }}</td>
      <td style="white-space:nowrap">{{ d.size_gb }} GB</td>
      <td>{{ d.media_type or '—' }}</td>
      <td>{{ d.interface_type or '—' }}</td>
      <td style="text-align:center">{{ d.partitions if d.partitions is not none else '—' }}</td>
      <td style="font-family:monospace;font-size:.75rem;color:#6b7280">{{ d.serial_number or '—' }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <!-- ── Display Adapters ─────────────────────────────────────────────── -->
  {% if inv.display_adapters %}
  <h2>Display Adapters</h2>
  <table>
    <thead><tr><th>Name</th><th>VRAM</th><th>Driver Version</th><th>Current Resolution</th></tr></thead>
    <tbody>
    {% for g in inv.display_adapters %}
    <tr>
      <td>{{ g.name }}</td>
      <td>{{ (g.vram_mb|string + ' MB') if g.vram_mb else '—' }}</td>
      <td style="font-family:monospace;font-size:.8rem;color:#6b7280">{{ g.driver_version or '—' }}</td>
      <td>{{ g.resolution or '—' }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <!-- ── Printers ─────────────────────────────────────────────────────── -->
  {% if inv.printers %}
  <h2>Printers</h2>
  <table>
    <thead><tr><th>Name</th><th>Driver</th><th>Default</th><th>Network</th></tr></thead>
    <tbody>
    {% for p in inv.printers %}
    <tr>
      <td>{{ p.name }}</td>
      <td style="color:#6b7280;font-size:.8rem">{{ p.driver_name or '—' }}</td>
      <td style="color:{% if p.is_default %}#4ade80{% else %}#6b7280{% endif %}">{{ '✓ Yes' if p.is_default else 'No' }}</td>
      <td>{{ 'Yes' if p.is_network else 'No' }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <!-- ── USB Devices ──────────────────────────────────────────────────── -->
  {% if inv.usb_devices %}
  <h2>USB Connected Devices</h2>
  <table>
    <thead><tr><th>Name</th><th>Manufacturer</th></tr></thead>
    <tbody>
    {% for u in inv.usb_devices %}
    <tr>
      <td>{{ u.name }}</td>
      <td style="color:#6b7280">{{ u.manufacturer or '—' }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <!-- ── Battery ──────────────────────────────────────────────────────── -->
  {% if inv.battery %}
  <h2>Battery</h2>
  <table>
    <thead><tr><th>Name</th><th>Charge Remaining</th><th>Design Capacity</th><th>Full Charge Capacity</th><th>Status</th></tr></thead>
    <tbody>
    <tr>
      <td>{{ inv.battery.name }}</td>
      <td>{{ (inv.battery.charge_remaining_pct|string + '%') if inv.battery.charge_remaining_pct is not none else '—' }}</td>
      <td>{{ (inv.battery.design_capacity_mwh|string + ' mWh') if inv.battery.design_capacity_mwh else '—' }}</td>
      <td>{{ (inv.battery.full_charge_capacity_mwh|string + ' mWh') if inv.battery.full_charge_capacity_mwh else '—' }}</td>
      <td>{{ inv.battery.status or '—' }}</td>
    </tr>
    </tbody>
  </table>
  {% endif %}

  <!-- ── Software Inventory ───────────────────────────────────────────── -->
  {% if inv.software %}
  <h2>Installed Software ({{ inv.software|length }})</h2>
  <input class="filter-input" type="text" id="sw-filter"
    placeholder="Filter by name, publisher, version…"
    oninput="filterTable('sw-table','sw-filter')">
  <table id="sw-table">
    <thead><tr><th>#</th><th>Name</th><th>Version</th><th>Publisher</th><th>Install Date</th></tr></thead>
    <tbody>
    {% for s in inv.software %}
    <tr>
      <td style="color:#4b5563;font-size:.75rem;width:2.5rem">{{ loop.index }}</td>
      <td>{{ s.name }}</td>
      <td style="color:#6b7280;font-size:.8rem;white-space:nowrap">{{ s.version or '—' }}</td>
      <td style="color:#6b7280;font-size:.8rem">{{ s.publisher or '—' }}</td>
      <td style="color:#6b7280;font-size:.8rem;white-space:nowrap">{{ s.install_date or '—' }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <!-- ── Network ──────────────────────────────────────────────────────── -->
  {% if inv.network_adapters %}
  <h2>Network Adapters</h2>
  <table>
    <thead><tr><th>Name</th><th>Description</th><th>MAC Address</th><th>IP Addresses</th><th>Speed</th><th>Status</th></tr></thead>
    <tbody>
    {% for a in inv.network_adapters %}
    <tr>
      <td>{{ a.name }}</td>
      <td style="color:#6b7280;font-size:.8rem">{{ a.description or '—' }}</td>
      <td style="font-family:monospace;font-size:.8rem">{{ a.mac_address or '—' }}</td>
      <td style="font-family:monospace;font-size:.78rem">{{ a.ip_addresses|join('<br>')|safe }}</td>
      <td style="white-space:nowrap">{{ (a.speed_mbps|string + ' Mbps') if a.speed_mbps else '—' }}</td>
      <td style="font-weight:600;color:{% if a.status == 'Up' %}#4ade80{% else %}#6b7280{% endif %}">{{ a.status }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <!-- ── Local Users ──────────────────────────────────────────────────── -->
  {% if inv.user_accounts %}
  <h2>Local User Accounts</h2>
  <table>
    <thead><tr><th>Username</th><th>Full Name</th><th>Enabled</th><th>Last Logon</th><th>Pwd Required</th><th>Pwd Expires</th><th>Groups</th></tr></thead>
    <tbody>
    {% for u in inv.user_accounts %}
    <tr>
      <td style="font-family:monospace;font-weight:600">{{ u.name }}</td>
      <td style="color:#6b7280">{{ u.full_name or '—' }}</td>
      <td style="color:{% if u.enabled %}#4ade80{% else %}#f87171{% endif %}">{{ 'Yes' if u.enabled else 'No' }}</td>
      <td style="color:#6b7280;font-size:.8rem">{{ u.last_logon[:16].replace('T',' ') if u.last_logon else 'Never' }}</td>
      <td>{{ 'Yes' if u.password_required else 'No' }}</td>
      <td>{{ 'Yes' if u.password_expires else 'No' }}</td>
      <td style="font-size:.78rem;color:#6b7280">{{ u.groups|join(', ') or '—' }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <!-- ── Shared Folders ───────────────────────────────────────────────── -->
  {% if inv.shared_folders %}
  <h2>Shared Folders</h2>
  <table>
    <thead><tr><th>Name</th><th>Path</th><th>Description</th></tr></thead>
    <tbody>
    {% for s in inv.shared_folders %}
    <tr>
      <td style="font-family:monospace">{{ s.name }}</td>
      <td>{{ s.path }}</td>
      <td style="color:#6b7280">{{ s.description or '—' }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <!-- ── Mapped Drives ────────────────────────────────────────────────── -->
  {% if inv.mapped_drives %}
  <h2>Mapped Network Drives</h2>
  <table>
    <thead><tr><th>Drive Letter</th><th>Remote Path</th></tr></thead>
    <tbody>
    {% for d in inv.mapped_drives %}
    <tr>
      <td style="font-family:monospace;font-weight:600">{{ d.drive_letter }}</td>
      <td>{{ d.remote_path }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <!-- ── Browser Extensions ───────────────────────────────────────────── -->
  {% if inv.browser_extensions %}
  <h2>Browser Extensions ({{ inv.browser_extensions|length }} across all profiles)</h2>
  {% set browsers = inv.browser_extensions|map(attribute='browser')|unique|sort|list %}
  {% for browser in browsers %}
  {% set browser_exts = inv.browser_extensions|selectattr('browser','equalto',browser)|list %}
  <details>
    <summary>{{ browser|title }} — {{ browser_exts|length }} extension{{ 's' if browser_exts|length != 1 else '' }}</summary>
    {% set profiles = browser_exts|map(attribute='profile')|unique|sort|list %}
    {% for profile in profiles %}
    {% set profile_exts = browser_exts|selectattr('profile','equalto',profile)|list %}
    <div style="padding:.4rem 1rem .2rem;background:#111827;font-size:.75rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid #1f2937">
      {{ profile or 'Default' }} — {{ profile_exts|length }} extension{{ 's' if profile_exts|length != 1 else '' }}
    </div>
    <table>
      <thead><tr><th>Name</th><th>Version</th><th>Extension ID</th><th>Enabled</th><th>Description</th></tr></thead>
      <tbody>
      {% for e in profile_exts|sort(attribute='name') %}
      <tr>
        <td>{{ e.name }}</td>
        <td style="color:#6b7280;font-size:.8rem;white-space:nowrap">{{ e.version or '—' }}</td>
        <td style="font-family:monospace;font-size:.72rem;color:#6b7280">{{ e.extension_id }}</td>
        <td style="color:{% if e.enabled %}#4ade80{% else %}#f87171{% endif %}">{{ 'Yes' if e.enabled else 'No' }}</td>
        <td style="color:#6b7280;font-size:.78rem">{{ e.description or '—' }}</td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
    {% endfor %}
  </details>
  {% endfor %}
  {% endif %}

  {% else %}
  <div style="text-align:center;padding:4rem 2rem;color:#4b5563">
    <p style="font-size:1.1rem;margin-bottom:.5rem">No inventory data collected.</p>
    <p>Inventory is only collected on Windows with a full (non-dry-run) scan.</p>
  </div>
  {% endif %}

  <p class="footer">Generated by SysPulse v{{ report.tool_version }}</p>
</div>
</div><!-- /tab-inventory -->

<!-- ════════════════════════════════════════════════════════════════════ -->
<!-- TAB 3 — NETWORK DISCOVERY                                          -->
<!-- ════════════════════════════════════════════════════════════════════ -->
<div id="tab-network" class="tab-pane">
<div class="container">

{% set inv = report.inventory %}
{% if inv and inv.network_hosts %}
  {% set win_count = inv.network_hosts | selectattr('os_guess','equalto','Windows') | list | length %}
  {% set lin_count = inv.network_hosts | selectattr('os_guess','equalto','Linux') | list | length %}
  {% set mac_count = inv.network_hosts | selectattr('os_guess','equalto','macOS') | list | length %}
  {% set amb_count = inv.network_hosts | selectattr('os_guess','equalto','Linux/macOS') | list | length %}
  {% set net_count = inv.network_hosts | selectattr('os_guess','equalto','Network Device') | list | length %}
  {% set unk_count = inv.network_hosts | selectattr('os_guess','equalto','Unknown') | list | length %}

  <h2>Network Hosts — {{ inv.network_hosts|length }} Discovered</h2>
  <div class="summary-grid" style="margin-bottom:1.5rem">
    <div class="summary-card"><div class="count" style="color:#60a5fa">{{ inv.network_hosts|length }}</div><div class="label">Total</div></div>
    <div class="summary-card"><div class="count" style="color:#93c5fd">{{ win_count }}</div><div class="label">Windows</div></div>
    <div class="summary-card"><div class="count" style="color:#86efac">{{ lin_count }}</div><div class="label">Linux</div></div>
    <div class="summary-card"><div class="count" style="color:#d1d5db">{{ mac_count }}</div><div class="label">macOS</div></div>
    {% if amb_count %}<div class="summary-card"><div class="count" style="color:#6ee7b7">{{ amb_count }}</div><div class="label">Linux/macOS</div></div>{% endif %}
    {% if net_count %}<div class="summary-card"><div class="count" style="color:#fbbf24">{{ net_count }}</div><div class="label">Network Device</div></div>{% endif %}
    {% if unk_count %}<div class="summary-card"><div class="count" style="color:#6b7280">{{ unk_count }}</div><div class="label">Unknown</div></div>{% endif %}
  </div>

  <input class="filter-input" type="text" id="net-filter"
    placeholder="Filter by IP, hostname, OS, vendor, port…"
    oninput="filterTable('net-table','net-filter')">

  <table id="net-table">
    <thead>
      <tr>
        <th>IP Address</th>
        <th>Hostname / NetBIOS</th>
        <th>OS Guess</th>
        <th>MAC / Vendor</th>
        <th>Open Ports &amp; Services</th>
        <th>TTL</th>
        <th>RTT</th>
      </tr>
    </thead>
    <tbody>
    {% for h in inv.network_hosts %}
    {% set os_color = '#93c5fd' if h.os_guess == 'Windows' else '#86efac' if h.os_guess == 'Linux' else '#d1d5db' if h.os_guess == 'macOS' else '#6ee7b7' if h.os_guess == 'Linux/macOS' else '#fbbf24' if h.os_guess == 'Network Device' else '#6b7280' %}
    {% set conf_color = '#4ade80' if h.os_confidence == 'high' else '#facc15' if h.os_confidence == 'medium' else '#6b7280' %}
    <tr{% if h.is_local %} style="background:#1a2234"{% endif %}>
      <td style="font-family:monospace;font-weight:600;white-space:nowrap">
        {{ h.ip }}{% if h.is_local %} <span style="color:#60a5fa;font-size:.7rem">(this machine)</span>{% endif %}
      </td>
      <td style="font-size:.82rem">
        {% if h.hostname %}<span style="color:#e5e7eb">{{ h.hostname }}</span>{% endif %}
        {% if h.netbios_name and h.netbios_name != h.hostname %}<br><span style="font-family:monospace;font-size:.75rem;color:#60a5fa" title="NetBIOS name">{{ h.netbios_name }}</span>{% endif %}
        {% if not h.hostname and not h.netbios_name %}<span style="color:#4b5563">—</span>{% endif %}
      </td>
      <td style="white-space:nowrap">
        <span style="font-weight:700;font-size:.82rem;color:{{ os_color }}">{{ h.os_guess }}</span><br>
        <span style="font-size:.7rem;color:{{ conf_color }}">{{ h.os_confidence }} confidence</span>
      </td>
      <td style="font-size:.78rem;color:#6b7280">
        {{ h.mac_address or '—' }}
        {% if h.vendor %}<br><span style="color:#9ca3af">{{ h.vendor }}</span>{% endif %}
      </td>
      <td>
        {% if h.services %}
          {% for svc in h.services %}
            <span style="display:inline-block;margin:.1rem .1rem .1rem 0;padding:.15rem .4rem;background:#1e293b;border:1px solid #334155;border-radius:3px;font-family:monospace;font-size:.7rem;color:#94a3b8;white-space:nowrap">{{ svc }}</span>
          {% endfor %}
        {% else %}<span style="color:#4b5563">—</span>{% endif %}
      </td>
      <td style="font-size:.78rem;color:#6b7280;text-align:center">{{ h.ttl if h.ttl else '—' }}</td>
      <td style="font-size:.78rem;color:#6b7280;white-space:nowrap">{{ (h.response_time_ms|string + ' ms') if h.response_time_ms is not none else '—' }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>

{% elif inv %}
  <div style="text-align:center;padding:4rem 2rem;color:#4b5563">
    <p style="font-size:1.1rem;margin-bottom:.5rem">No network hosts discovered.</p>
    <p>The local /24 subnet scan found no live hosts, or the scan was skipped.</p>
  </div>
{% else %}
  <div style="text-align:center;padding:4rem 2rem;color:#4b5563">
    <p style="font-size:1.1rem;margin-bottom:.5rem">No inventory data collected.</p>
    <p>Network discovery only runs on Windows with a full (non-dry-run) scan.</p>
  </div>
{% endif %}

  <p class="footer">Generated by SysPulse v{{ report.tool_version }}</p>
</div>
</div><!-- /tab-network -->

<script>
function switchTab(name, btn) {
  document.querySelectorAll('.tab-pane').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
}
function filterTable(tableId, inputId) {
  var filter = document.getElementById(inputId).value.toLowerCase();
  var rows = document.getElementById(tableId).querySelectorAll('tbody tr');
  rows.forEach(function(row){
    row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
  });
}
</script>
</body>
</html>
